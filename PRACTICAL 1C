sgpi = float(input("Enter your SGPI: "))

if 9.00 <= sgpi <= 10.00:
    print("Grade: O")
elif 8.00 <= sgpi <= 8.99:
    print("Grade: A+")
elif 7.00 <= sgpi <= 7.99:
    print("Grade: A")
elif 6.00 <= sgpi <= 6.99:
    print("Grade: B+")
elif 5.50 <= sgpi <= 5.99:
    print("Grade: B")
elif 5.00 <= sgpi <= 5.49:
    print("Grade: C")
elif 4.00 <= sgpi <= 4.99:
    print("Grade: P")
elif sgpi < 4.00:
    print("Grade: F")
else:
    print("Invalid SGPI")
